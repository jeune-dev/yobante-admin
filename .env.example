# Backend APIs (Development)
# Attention : le backend boutique monte ses routes sous /api/v1, pas /api.
# Avec /api, toutes les requêtes partent en 404 et les écrans restent vides.
VITE_SHOP_API_URL=http://localhost:5000/api/v1
VITE_SHIPMENT_API_URL=http://localhost:5001/api

# App Configuration
VITE_APP_NAME=Yobante Admin
VITE_APP_VERSION=1.0.0

# Production URLs (commented out - uncomment for production)
# VITE_SHOP_API_URL=https://api.yobante-boutique.com
# VITE_SHIPMENT_API_URL=https://api.yobante-colis.com
